# Copy to .env and fill. The key NEVER reaches the browser.
OPENROUTER_API_KEY=sk-or-...
# Optional: shown to OpenRouter for routing/ranking. Safe to leave default.
OPENROUTER_REFERER=http://localhost:5173
OPENROUTER_TITLE=Valuation Pipeline Runner
# SQLite file location (relative to backend/) — used only when DATABASE_URL unset.
PIPELINE_DB=pipeline.db

# Prod persistence: Supabase Postgres connection string (URI). When set, the
# app uses Postgres instead of SQLite. Use the Supabase "Connection string"
# (Session/Transaction pooler) and keep sslmode=require.
# DATABASE_URL=postgresql://postgres.<ref>:<pw>@aws-...pooler.supabase.com:6543/postgres?sslmode=require

# Team access gate (shared password). Unset locally = auth disabled.
# APP_TOKEN=
# Comma-separated allowed origins for CORS in prod (your Vercel domain).
# ALLOWED_ORIGINS=https://your-app.vercel.app

# --- Valuatum JSON export (Stage 0 FAKTAT data) ---
# Required for /rest/modeldata (DCF/WACC/EVA/forecasts).
VALUATUM_TOKEN=
# Strongly recommended: Profinder MCP streamable-HTTP URL for historical actuals.
VALU_MCP_PROFINDER_URL=
